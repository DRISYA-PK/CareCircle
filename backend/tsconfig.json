{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "sourceMap": true,

    "resolveJsonModule": true,
    "isolatedModules": false
  },
  "include": ["src"]
}
